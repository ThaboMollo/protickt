# Supabase (Project Settings → API). Service-role key: API ONLY, never in a client app.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Paystack (Dashboard → Settings → API Keys). Use sk_test_... until launch.
PAYSTACK_SECRET_KEY=sk_test_xxx

# Buyer-facing web app URL (Paystack redirects and ticket links point here).
WEB_URL=http://localhost:3000

# Allowed browser origins for CORS (comma separated).
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# Optional: Resend for ticket emails. Emails are skipped if unset.
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=ProTickt <tickets@yourdomain.com>

# Shared secret for the order-expiry cron endpoint.
CRON_SECRET=change-me

PORT=4000
