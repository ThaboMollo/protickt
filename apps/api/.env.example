# Supabase (Project Settings → API). Service-role key: API ONLY, never in a client app.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Master key for encrypting per-organization Paystack keys at rest.
# Generate with: openssl rand -base64 32
# Each org's Paystack keys are set via PUT /admin/orgs/:id/paystack-keys.
PAYSTACK_KEY_ENCRYPTION_KEY=

# Allowed browser origins for CORS (comma separated). Every tenant buyer-site
# domain must be listed here or its checkout POST will be blocked.
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# Optional: Resend for ticket emails. Emails are skipped if unset.
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=ProTickt <tickets@yourdomain.com>

# Shared secret for the order-expiry cron endpoint.
CRON_SECRET=change-me

PORT=4000
